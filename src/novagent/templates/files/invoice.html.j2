<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Invoice {{ invoice.invoice_number }}</title>
<style>
  @page { margin: 2cm; }
  body { font-family: 'Helvetica', 'Arial', sans-serif; font-size: 11pt; color: #1f2937; margin: 0; padding: 0; }
  .header { border-bottom: 3px solid {{ primary_color }}; padding-bottom: 20px; margin-bottom: 30px; }
  .header h1 { color: {{ primary_color }}; font-size: 28pt; margin: 0 0 5px 0; }
  .header .tagline { color: #6b7280; font-size: 10pt; }
  .header .invoice-num { float: right; text-align: right; }
  .header .invoice-num h2 { color: {{ accent_color }}; margin: 0; font-size: 18pt; }
  .client-info { margin-bottom: 30px; }
  .client-info h3 { color: {{ primary_color }}; margin: 0 0 5px 0; font-size: 12pt; }
  table.items { width: 100%; border-collapse: collapse; margin-bottom: 30px; }
  table.items th { background: {{ primary_color }}; color: white; padding: 10px 12px; text-align: left; font-size: 10pt; text-transform: uppercase; letter-spacing: 0.5px; }
  table.items td { padding: 10px 12px; border-bottom: 1px solid #e5e7eb; }
  table.items tr:last-child td { border-bottom: 2px solid {{ primary_color }}; }
  table.items .amount { text-align: right; }
  .totals { float: right; width: 300px; }
  .totals table { width: 100%; }
  .totals td { padding: 6px 12px; }
  .totals .label { text-align: right; color: #6b7280; }
  .totals .value { text-align: right; font-weight: bold; }
  .totals .grand-total td { border-top: 2px solid {{ primary_color }}; padding-top: 10px; font-size: 14pt; color: {{ primary_color }}; }
  .footer { margin-top: 50px; padding-top: 15px; border-top: 1px solid #e5e7eb; font-size: 9pt; color: #9ca3af; text-align: center; }
  .status-badge { display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 9pt; font-weight: bold; text-transform: uppercase; }
  .status-draft { background: #fef3c7; color: #92400e; }
  .status-sent { background: #dbeafe; color: #1e40af; }
  .status-paid { background: #d1fae5; color: #065f46; }
  .status-overdue { background: #fee2e2; color: #991b1b; }
</style>
</head>
<body>

<div class="header">
  <div class="invoice-num">
    <h2>{{ invoice.invoice_number }}</h2>
    <span class="status-badge status-{{ invoice.status.value }}">{{ invoice.status.value }}</span>
  </div>
  <h1>{{ brand_name }}</h1>
  <div class="tagline">{{ tagline }}</div>
</div>

<div class="client-info">
  <h3>Bill To:</h3>
  <p>{{ invoice.client_name }}<br>
  {% if invoice.client_address %}{{ invoice.client_address | nl2br }}{% endif %}</p>
  <p><strong>Issue Date:</strong> {{ invoice.issue_date | date }}<br>
  <strong>Due Date:</strong> {{ invoice.due_date | date }}</p>
</div>

<table class="items">
  <thead>
    <tr>
      <th>Description</th>
      <th class="amount">Qty</th>
      <th class="amount">Unit Price</th>
      <th class="amount">Total</th>
    </tr>
  </thead>
  <tbody>
    {% for item in invoice.line_items %}
    <tr>
      <td>{{ item.description }}</td>
      <td class="amount">{{ item.quantity }}</td>
      <td class="amount">{{ item.unit_price | currency }}</td>
      <td class="amount">{{ item.total | currency }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

<div class="totals">
  <table>
    <tr><td class="label">Subtotal</td><td class="value">{{ invoice.subtotal | currency }}</td></tr>
    {% if invoice.tax_rate > 0 %}
    <tr><td class="label">Tax ({{ (invoice.tax_rate * 100) | int }}%)</td><td class="value">{{ invoice.tax_amount | currency }}</td></tr>
    {% endif %}
    <tr class="grand-total"><td class="label">Total</td><td class="value">{{ invoice.total | currency }} {{ invoice.currency }}</td></tr>
  </table>
</div>

<div style="clear: both;"></div>

<div class="footer">
  {{ brand_name }} — {{ tagline }} | Generated {{ "now" | date }}
</div>

</body>
</html>
